# MD通 Environment Variables

# AI API Key（优先级：界面/config.json > MDTONG_AI_API_KEY > ANTHROPIC_API_KEY）
MDTONG_AI_API_KEY=your_ai_api_key_here

# 兼容 Anthropic SDK 的 API Key 环境变量
ANTHROPIC_API_KEY=your_anthropic_compatible_api_key_here

# AI 服务地址与模型
MDTONG_AI_BASE_URL=https://api.aipaibox.com
MDTONG_AI_MODEL=gpt-5.5

# 模型参数（可按服务商实际限制调整）
MDTONG_AI_CONTEXT_TOKENS=1000000
MDTONG_AI_MAX_TOKENS=128000
MDTONG_AI_TEMPERATURE=0.2
MDTONG_AI_TOP_P=0.95

# Agent Skill Generator Environment Variables
FIRECRAWL_API_KEY=your_firecrawl_api_key_here
EXA_API_KEY=your_exa_api_key_here
